<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= user.store_name %> 受付</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Hiragino Sans',sans-serif;background:#f0f2f5;color:#1a1a1a;font-size:14px}
.header{background:#fff;border-bottom:1px solid #e5e7eb;padding:10px 20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.header h1{font-size:16px;font-weight:600}
.store-badge{background:#2d7a4f;color:#fff;border-radius:6px;padding:4px 14px;font-size:14px;font-weight:600}
.header input[type=date]{padding:6px 10px;border:1px solid #ddd;border-radius:6px;font-size:14px}
.header button.day{padding:8px 16px;border:1px solid #ddd;border-radius:6px;background:#f5f5f5;font-size:14px;cursor:pointer}
.header .spacer{flex:1}
.logout-btn{padding:6px 14px;border:1px solid #ddd;border-radius:6px;background:#fff;font-size:13px;cursor:pointer;color:#666}
.main{display:grid;grid-template-columns:340px 1fr;gap:12px;padding:12px;height:calc(100vh - 57px)}
.panel{background:#fff;border-radius:10px;border:1px solid #e5e7eb;display:flex;flex-direction:column;overflow:hidden}
.panel-header{padding:12px 16px;border-bottom:1px solid #e5e7eb;font-weight:600;font-size:15px;display:flex;justify-content:space-between;align-items:center}
.panel-header .count{font-size:13px;color:#888;font-weight:400}
.timeline-list{flex:1;overflow-y:auto}
.timeline-item{display:flex;align-items:center;padding:12px 16px;border-bottom:1px solid #f0f0f0;gap:10px}
.t-time{font-size:17px;font-weight:700;min-width:52px}
.t-room{background:#e8f5ee;color:#2d7a4f;border-radius:5px;padding:3px 10px;font-size:14px;font-weight:600;min-width:42px;text-align:center}
.t-course{color:#555;font-size:14px;min-width:44px}
.t-name{color:#333;font-size:14px;flex:1}
.t-del{color:#c0392b;font-size:13px;cursor:pointer;border:none;background:none;padding:4px 8px;border-radius:4px}
.t-del:hover{background:#fef2f2}
.empty-msg{padding:40px 16px;text-align:center;color:#aaa}
.grid-scroll{flex:1;overflow:auto}
.grid{border-collapse:collapse;width:100%;min-width:360px}
.grid th{position:sticky;top:0;background:#fff;z-index:10;padding:10px;font-size:14px;font-weight:600;color:#444;border-bottom:2px solid #e5e7eb;text-align:center;white-space:nowrap}
.grid th:first-child{background:#f9f9f9}
.grid td{padding:0;border:1px solid #f0f0f0;text-align:center;height:40px;min-width:70px}
.grid td:first-child{padding:4px 12px;font-size:13px;color:#888;background:#f9f9f9;white-space:nowrap;position:sticky;left:0}
.cell-free{background:#fff;cursor:pointer}
.cell-free:hover{background:#e8f5ee}
.cell-blocked{background:repeating-linear-gradient(45deg,#f5f5f5,#f5f5f5 4px,#e8e8e8 4px,#e8e8e8 8px);cursor:not-allowed}
.room-memo{font-size:10px;color:#2d7a4f;font-weight:normal;margin-top:2px}
.room-blocked{font-size:10px;color:#c0392b;font-weight:normal;margin-top:2px}
.blk-btn{font-size:10px;padding:2px 6px;margin-top:3px;border:1px solid #ddd;border-radius:4px;background:#fff;cursor:pointer}
.cell-booked{background:#fde8e8}
.cell-cleaning{background:#eee}
.cell-label{font-size:12px;color:#c0392b;font-weight:600}
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:100;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:#fff;border-radius:12px;padding:24px;width:100%;max-width:440px}
.modal h2{font-size:17px;font-weight:600;margin-bottom:18px}
.form-row{display:flex;gap:12px;margin-bottom:16px}
.form-group{flex:1}
.form-group label{display:block;font-size:13px;color:#666;margin-bottom:6px}
.form-group input,.form-group select{width:100%;padding:10px;border:1px solid #ddd;border-radius:8px;font-size:15px}
.course-btns{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:10px}
.course-btn{padding:12px 4px;border:1px solid #ddd;border-radius:8px;background:#f5f5f5;font-size:15px;font-weight:600;cursor:pointer}
.course-btn.active{background:#2d7a4f;color:#fff;border-color:#2d7a4f}
.name-toggle{display:flex;gap:16px;margin-bottom:10px}
.name-toggle label{display:flex;align-items:center;gap:6px;font-size:14px;cursor:pointer}
.modal-actions{display:flex;gap:10px;margin-top:20px}
.btn-primary{flex:1;padding:12px;background:#2d7a4f;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:600;cursor:pointer}
.btn-cancel{padding:12px 20px;background:#f5f5f5;border:1px solid #ddd;border-radius:8px;font-size:15px;cursor:pointer}
.error-msg{color:#c0392b;font-size:13px;margin-top:8px;display:none}
.now-row td{border-top:2px solid #e3342f !important}
.now-row td:first-child{color:#e3342f;font-weight:700}
.half-row td{border-top:1px solid #d8d8d8}
.ext-badge{background:#fff3e0;color:#e67e22;font-size:10px;padding:1px 5px;border-radius:3px;font-weight:600}
.shift-badge{background:#e3f2fd;color:#1976d2;font-size:10px;padding:1px 5px;border-radius:3px;font-weight:600}
.t-ext{color:#e67e22;font-size:13px;cursor:pointer;border:1px solid #fce0c0;background:#fff8f0;padding:4px 8px;border-radius:4px}
.t-shift{color:#1976d2;font-size:13px;cursor:pointer;border:1px solid #cfe5fb;background:#f5fafe;padding:4px 8px;border-radius:4px}
.ext-btns,.shift-btns{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:10px}
.ext-btn,.shift-btn{padding:12px 4px;border:1px solid #ddd;border-radius:8px;background:#f5f5f5;font-size:15px;font-weight:600;cursor:pointer}
.ext-btn.active,.shift-btn.active{background:#2d7a4f;color:#fff;border-color:#2d7a4f}
.warn-msg{background:#fff8e1;color:#b26a00;font-size:13px;padding:10px 12px;border-radius:8px;margin-top:12px;line-height:1.5}
@media(max-width:768px){.main{grid-template-columns:1fr;grid-template-rows:auto 1fr}.panel.timeline{max-height:300px}}
</style>
</head>
<body>
<div class="header">
<span class="store-badge"><%= user.store_name %></span>
<h1>受付</h1>
<input type="date" id="dateInput" value="<%= new Date().toISOString().slice(0,10) %>">
<button class="day" onclick="setToday()">今日</button>
<button class="day" onclick="setYesterday()">昨日</button>
<button class="day" id="notifyBtn" onclick="toggleNotify()" style="border-color:#e67e22;color:#e67e22">🔔 通知（画面を触ると開始）</button>
<div class="spacer"></div>
<a href="/reception/rooms" style="font-size:13px;color:#2d7a4f;text-decoration:none;padding:6px 12px;border:1px solid #2d7a4f;border-radius:6px">部屋管理</a>
<form action="/logout" method="GET" style="margin:0"><button class="logout-btn" type="submit">ログアウト</button></form>
</div>
<div class="main">
<div class="panel timeline">
<div class="panel-header"><span>本日の予約</span><span class="count" id="cnt">0件</span></div>
<div class="timeline-list" id="list"><div class="empty-msg">予約はありません</div></div>
</div>
<div class="panel">
<div class="panel-header"><span>空き状況</span><span class="count">空きをタップで予約</span></div>
<div class="grid-scroll"><table class="grid" id="grid"><thead id="gh"></thead><tbody id="gb"></tbody></table></div>
</div>
</div>
<div class="modal-overlay" id="mo">
<div class="modal">
<h2>予約追加</h2>
<div class="form-row">
<div class="form-group"><label>部屋</label><select id="mRoom"></select></div>
<div class="form-group"><label>開始時刻</label><input type="time" id="mTime"></div>
</div>
<div class="form-group" style="margin-bottom:16px">
<label>コース時間</label>
<div class="course-btns" id="cbtns"></div>
<div style="display:flex;align-items:center;gap:8px">
<span style="font-size:13px;color:#666">手入力:</span>
<input type="number" id="cManual" placeholder="分" min="5" step="5" style="width:80px;padding:8px;border:1px solid #ddd;border-radius:6px">
<span style="font-size:13px;color:#666">分</span>
</div>
</div>
<div class="form-group" style="margin-bottom:8px">
<label>名前</label>
<div class="name-toggle">
<label><input type="radio" name="nt" value="code" checked> コード</label>
<label><input type="radio" name="nt" value="manual"> 手入力</label>
</div>
<select id="mCode"></select>
<input type="text" id="mName" placeholder="客名・メモ" style="display:none;width:100%;padding:10px;border:1px solid #ddd;border-radius:8px">
</div>
<div class="error-msg" id="err"></div>
<div class="modal-actions">
<button class="btn-cancel" onclick="closeM()">キャンセル</button>
<button class="btn-primary" onclick="submitB()">予約追加</button>
</div>
</div>
</div>
<div class="modal-overlay" id="extMo">
<div class="modal">
<h2>延長</h2>
<p class="msub" id="extSub" style="font-size:12px;color:#888;margin-bottom:14px"></p>
<div class="form-group" style="margin-bottom:8px">
<label style="display:block;font-size:13px;color:#666;margin-bottom:6px">延長時間</label>
<div class="ext-btns" id="extBtns"></div>
<div style="display:flex;align-items:center;gap:8px">
<span style="font-size:13px;color:#666">手入力:</span>
<input type="number" id="extManual" placeholder="分" min="5" step="5" style="width:80px;padding:8px;border:1px solid #ddd;border-radius:6px">
<span style="font-size:13px;color:#666">分</span>
</div>
</div>
<div class="error-msg" id="extErr"></div>
<div class="warn-msg">延長したら、お店にも電話で延長を伝えてください。</div>
<div class="modal-actions">
<button class="btn-cancel" onclick="closeExt()">キャンセル</button>
<button class="btn-primary" onclick="doExtend()">延長する</button>
</div>
</div>
</div>
<div class="modal-overlay" id="shiftMo">
<div class="modal">
<h2>時間をずらす</h2>
<p class="msub" id="shiftSub" style="font-size:12px;color:#888;margin-bottom:14px"></p>
<div class="form-group" style="margin-bottom:8px">
<label style="display:block;font-size:13px;color:#666;margin-bottom:6px">新しい開始時刻</label>
<input type="time" id="shiftTime" step="300" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:8px;font-size:16px">
</div>
<div class="error-msg" id="shiftErr"></div>
<div class="warn-msg">時間を変更したら、お店にも電話で変更を伝えてください。</div>
<div class="modal-actions">
<button class="btn-cancel" onclick="closeShift()">キャンセル</button>
<button class="btn-primary" onclick="doShift()">変更する</button>
</div>
</div>
</div>
<script>
const rooms=<%- JSON.stringify(rooms) %>;
const partners=<%- JSON.stringify(partners) %>;
const durations=<%- JSON.stringify(durations) %>;
let selCourse=null;
let curDate=document.getElementById('dateInput').value;
document.getElementById('dateInput').addEventListener('change',e=>{curDate=e.target.value;load();});
function setToday(){curDate=new Date().toISOString().slice(0,10);document.getElementById('dateInput').value=curDate;load();}
function setYesterday(){const d=new Date();d.setDate(d.getDate()-1);curDate=d.toISOString().slice(0,10);document.getElementById('dateInput').value=curDate;load();}
async function load(){const res=await fetch(`/api/bookings?date=${curDate}`);const bk=await res.json();renderList(bk);renderGrid(bk);}
async function toggleBlock(id,cur){
if(cur){await fetch('/api/rooms/'+id+'/block',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({blocked:false})});location.reload();}
else{const reason=prompt('利用不可の理由（任意・空欄でもOK）');if(reason===null)return;await fetch('/api/rooms/'+id+'/block',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({blocked:true,reason})});location.reload();}
}
let lastBk=[];
function renderList(bk){
lastBk=bk;
document.getElementById('cnt').textContent=bk.length+'件';
if(!bk.length){document.getElementById('list').innerHTML='<div class="empty-msg">予約はありません</div>';return;}
const s=[...bk].sort((a,b)=>a.start_at.localeCompare(b.start_at));
const past=isPast();
document.getElementById('list').innerHTML=s.map(b=>{const t=b.start_at.slice(11,16);const nm=b.partner_code||b.client_name||'-';let badge='';if(b.extended)badge+=' <span class="ext-badge">延長済</span>';if(b.shifted)badge+=' <span class="shift-badge">時間変更</span>';const delBtn=past?'':`<button class="t-del" onclick="delB(${b.id})">削除</button>`;return `<div class="timeline-item"><span class="t-time">${t}</span><span class="t-room">${b.room_name}</span><span class="t-course">${b.course_minutes}分${badge}</span><span class="t-name">${nm}</span><button class="t-shift" onclick="openShift(${b.id})">時間</button><button class="t-ext" onclick="openExt(${b.id})">延長</button>${delBtn}</div>`;}).join('');
}
function nowSlot(){const n=new Date();let h=n.getHours();if(h<10)h+=24;return h*60+n.getMinutes();}
function isToday(){return curDate===new Date().toISOString().slice(0,10);}
function isPast(){return curDate<new Date().toISOString().slice(0,10);}
function renderGrid(bk){
document.getElementById('gh').innerHTML='<tr><th>時間</th>'+rooms.map(r=>`<th>${r.name}${r.memo?`<div class="room-memo">${r.memo}</div>`:''}${r.blocked?`<div class="room-blocked">利用不可${r.block_reason?'：'+r.block_reason:''}</div>`:''}<br><button class="blk-btn" onclick="toggleBlock(${r.id},${r.blocked})">${r.blocked?'解除':'利用不可'}</button></th>`).join('')+'</tr>';
const map={};rooms.forEach(r=>map[r.id]=[]);
bk.forEach(b=>{if(map[b.room_id]){const st=tm(b.start_at.slice(11,16));map[b.room_id].push({start:st,end:st+b.block_minutes,course:st+b.course_minutes});}});
const ns=nowSlot();const today=isToday();
const rows=[];
for(let h=10;h<34;h++){for(let m=0;m<60;m+=5){
const tot=h*60+m;const dh=h>=24?h-24:h;
const lb=`${String(dh).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
const isNow=today&&ns>=tot&&ns<tot+5;
const showLabel=(m%30===0);
let c=`<td>${showLabel?lb:''}</td>`;
rooms.forEach(r=>{if(r.blocked){c+=`<td class="cell-blocked"></td>`;return;}const st=cellStatus(map[r.id],tot);if(st==='booked')c+=`<td class="cell-booked">${showLabel?'<span class="cell-label">×</span>':''}</td>`;else if(st==='cleaning')c+=`<td class="cell-cleaning"></td>`;else c+=`<td class="cell-free" onclick="openM('${r.id}','${lb}')"></td>`;});
rows.push(`<tr${isNow?' id="nowRow" class="now-row"':''}${showLabel?' class="half-row"':''}>${c}</tr>`);
}}
document.getElementById('gb').innerHTML=rows.join('');
if(today){const nr=document.getElementById('nowRow');if(nr)nr.scrollIntoView({block:'center'});}
}
function cellStatus(bs,slot){for(const b of bs){if(slot>=b.start&&slot<b.course)return 'booked';if(slot>=b.course&&slot<b.end)return 'cleaning';}return 'free';}
function tm(s){const[h,m]=s.split(':').map(Number);return h*60+m;}
function openM(rid,time){
document.getElementById('mRoom').innerHTML=rooms.map(r=>`<option value="${r.id}" ${r.id==rid?'selected':''}>${r.name}</option>`).join('');
document.getElementById('mTime').value=time;
document.getElementById('cbtns').innerHTML=durations.map(d=>`<button class="course-btn" onclick="selC(this,${d.minutes})">${d.minutes}分</button>`).join('');
selCourse=null;document.getElementById('cManual').value='';
document.getElementById('mCode').innerHTML='<option value="">選択</option>'+partners.map(p=>`<option value="${p.code}">${p.code}</option>`).join('');
document.querySelectorAll('input[name=nt]').forEach(r=>r.onchange=e=>{document.getElementById('mCode').style.display=e.target.value==='code'?'':'none';document.getElementById('mName').style.display=e.target.value==='manual'?'':'none';});
document.querySelector('input[name=nt][value=code]').checked=true;
document.getElementById('mCode').style.display='';document.getElementById('mName').style.display='none';
document.getElementById('err').style.display='none';
document.getElementById('mo').classList.add('open');
}
function selC(btn,min){document.querySelectorAll('.course-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');selCourse=min;document.getElementById('cManual').value='';}
function closeM(){document.getElementById('mo').classList.remove('open');}
async function submitB(){
const room_id=document.getElementById('mRoom').value;
const time=document.getElementById('mTime').value;
const man=parseInt(document.getElementById('cManual').value);
const nt=document.querySelector('input[name=nt]:checked').value;
const partner_code=nt==='code'?document.getElementById('mCode').value:null;
const client_name=nt==='manual'?document.getElementById('mName').value:null;
let course_minutes;
if(selCourse)course_minutes=selCourse;
else if(!isNaN(man)&&man>0)course_minutes=man;
else{showErr('コース時間を選んでください');return;}
const start_at=`${curDate}T${time}`;
const res=await fetch('/api/bookings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({room_id,start_at,course_minutes,partner_code,client_name})});
const d=await res.json();
if(!res.ok){showErr(d.error);return;}
closeM();load();
}
async function delB(id){if(!confirm('削除しますか？'))return;await fetch(`/api/bookings/${id}`,{method:'DELETE'});load();}
function showErr(m){const e=document.getElementById('err');e.textContent=m;e.style.display='block';}
document.getElementById('mo').addEventListener('click',e=>{if(e.target===document.getElementById('mo'))closeM();});

// ===== 予約 通知システム（新規/削除/変更を音で区別・マリンバ音色）=====
const VOL=0.85;                // 通知音の音量（0〜1。最大1.0）
let notifyOn=false;            // 通知が実際に有効か（音の許可が取れてON状態か）
let userDisabled=false;        // ユーザーが手動でOFFにしたか（trueなら自動ONしない）
let snapMap=null;              // 既知の予約スナップショット（id -> 文字列化した状態）。初回はnull
let audioCtx=null;             // 音声コンテキスト
let titleBlink=null;           // タブ点滅タイマー
const baseTitle=document.title;

// 通知を有効化（音の許可を取る）。ユーザー操作のタイミングで呼ぶ必要がある。
function enableNotify(playTest){
try{if(!audioCtx)audioCtx=new (window.AudioContext||window.webkitAudioContext)();}catch(e){}
if(audioCtx&&audioCtx.state==='suspended'){try{audioCtx.resume();}catch(e){}}
notifyOn=true;userDisabled=false;
const btn=document.getElementById('notifyBtn');
btn.textContent='🔔 通知ON';btn.style.borderColor='#2d7a4f';btn.style.color='#2d7a4f';
if(playTest)soundNew();
}
function disableNotify(){
notifyOn=false;userDisabled=true;
const btn=document.getElementById('notifyBtn');
btn.textContent='🔔 通知OFF';btn.style.borderColor='#c0392b';btn.style.color='#c0392b';
stopBlink();
}
// ボタンを押したとき：ON⇔OFF切替（ONにするときはテスト音を鳴らす）
function toggleNotify(){if(notifyOn)disableNotify();else enableNotify(true);}
// 画面を最初に触ったら自動的に通知ON（手動OFF済みなら何もしない）。音の許可はこの操作で取れる。
function autoEnableOnce(){
if(!notifyOn&&!userDisabled)enableNotify(false); // 自動ONは無音（驚かせない）
}
document.addEventListener('click',autoEnableOnce);
document.addEventListener('touchstart',autoEnableOnce,{passive:true});
// 1音（マリンバ＝triangle波）。freq:周波数 delay:開始遅延 dur:長さ mul:音量倍率
function tone(freq,delay,dur,mul){
if(!audioCtx)return;
try{
const t=audioCtx.currentTime+delay;
const o=audioCtx.createOscillator();const g=audioCtx.createGain();
o.connect(g);g.connect(audioCtx.destination);
o.type='triangle';o.frequency.value=freq;
const peak=Math.max(VOL*mul,0.0002);
g.gain.setValueAtTime(0.0001,t);
g.gain.exponentialRampToValueAtTime(peak,t+0.012);
g.gain.exponentialRampToValueAtTime(0.0001,t+dur);
o.start(t);o.stop(t+dur+0.02);
}catch(e){}
}
// 新規：マリンバ上昇（ポロロン♪）
function soundNew(){tone(587,0,0.45,1.0);tone(784,0.12,0.45,1.0);tone(988,0.24,0.6,1.0);}
// 削除：マリンバ下降（ロロン↓）
function soundDel(){tone(784,0,0.4,0.9);tone(587,0.12,0.5,0.9);tone(440,0.24,0.6,0.9);}
// 変更（延長・時間ずらし）：軽い単音（ポン）
function soundChg(){tone(660,0,0.3,0.9);}

function flashBadge(color){
const c=document.getElementById('cnt');
c.style.transition='none';c.style.background=color;c.style.color='#fff';c.style.borderRadius='6px';c.style.padding='2px 8px';
setTimeout(()=>{c.style.transition='all 1.2s';c.style.background='';c.style.color='';},80);
}
function startBlink(msg){
stopBlink();
let on=true;
titleBlink=setInterval(()=>{document.title=on?`🔴 ${msg}`:baseTitle;on=!on;},700);
}
function stopBlink(){if(titleBlink){clearInterval(titleBlink);titleBlink=null;document.title=baseTitle;}}
window.addEventListener('focus',stopBlink);
document.addEventListener('click',()=>{if(titleBlink)stopBlink();});

// 1予約の状態を1つの文字列にする（変化検知用）
function snapKey(r){return `${r.start_at}|${r.course_minutes}|${r.extended}|${r.shifted}`;}

async function checkNew(){
try{
const res=await fetch('/api/booking-ids');
if(!res.ok)return;
const rows=await res.json();
const cur=new Map();rows.forEach(r=>cur.set(r.id,snapKey(r)));
if(snapMap===null){snapMap=cur;return;} // 初回は記録だけ（鳴らさない）

let added=0,removed=0,changed=0;
// 新規・変更を判定
cur.forEach((key,id)=>{
if(!snapMap.has(id))added++;
else if(snapMap.get(id)!==key)changed++;
});
// 削除を判定
snapMap.forEach((key,id)=>{if(!cur.has(id))removed++;});

snapMap=cur; // スナップショット更新

if(notifyOn&&(added||removed||changed)){
// 優先度：新規 > 削除 > 変更（同時に起きたら新規を優先して鳴らす）
if(added){soundNew();flashBadge('#2d7a4f');startBlink(`新規予約 ${added}件`);}
else if(removed){soundDel();flashBadge('#c0392b');startBlink(`予約削除 ${removed}件`);}
else if(changed){soundChg();flashBadge('#1976d2');startBlink(`予約変更 ${changed}件`);}
load(); // 一覧も即更新
}
}catch(e){}
}
// ===== ここまで通知システム =====

load();
setInterval(load,30000);
checkNew();
setInterval(checkNew,30000);


</script>
</body>
</html>
